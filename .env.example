# =============================================================================
# Namaskah SMS — Environment Template
# =============================================================================
# Copy this file:  cp .env.example .env
# Then fill in your values.
# =============================================================================

# --- Core ---
ENVIRONMENT=development
BASE_URL=http://localhost:8000
SECRET_KEY=local-dev-secret-key-1234567890abcdefghijklmnop
JWT_SECRET_KEY=local-jwt-secret-key-67890abcdefghijklmnopqrst

# --- Database ---
DATABASE_URL=sqlite:///./data/namaskah.db

# --- Redis ---
REDIS_URL=redis://localhost:6379/0

# --- Admin ---
ADMIN_EMAIL=admin@namaskah.app
ADMIN_PASSWORD=YourAdminPassword

# --- Paystack ---
PAYSTACK_PUBLIC_KEY=pk_test_xxxxxxxxxxxxxxxxxxxxxxxxxxxx
PAYSTACK_SECRET_KEY=sk_test_xxxxxxxxxxxxxxxxxxxxxxxxxxxx

# --- SMS Providers (fill the ones you use) ---
TEXTVERIFIED_API_KEY=
TEXTVERIFIED_EMAIL=
TELNYX_API_KEY=
FIVESIM_API_KEY=
PVAPINS_API_KEY=
SMSPOOL_API_KEY=

# --- Email ---
RESEND_API_KEY=

# --- Carrier Lookup ---
NUMVERIFY_API_KEY=

# --- Pricing ---
PRICE_MARKUP=1.8

# --- CORS ---
CORS_ORIGINS=http://localhost:3000,http://localhost:8000

# --- Google OAuth ---
GOOGLE_CLIENT_ID=

# --- Crypto Wallets (optional) ---
BITCOIN_ADDRESS=
ETHEREUM_ADDRESS=
SOLANA_ADDRESS=
USDT_ADDRESS=

# --- Monitoring (optional) ---
SENTRY_DSN=
